{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/config", "dest": "/api/config.py" },
    { "src": "/api/save", "dest": "/api/save.py" },
    { "src": "/api/trigger", "dest": "/api/trigger.py" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
